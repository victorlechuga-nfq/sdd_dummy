# Plantilla de variables de entorno. Copia este fichero a .env y rellena los valores.
# .env esta en .gitignore y NUNCA se versiona.

# Base de datos
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mdq

# Entorno de ejecucion: sandbox | prod
APP_ENV=sandbox

# Claves / secretos (rellenar en .env, dejar vacio aqui)
API_KEY=
